            android:exported="false" />
        <activity
            android:name="swasi.android.play.youtubeTutor.scaffolds.AppBarAndSnackbarActivity"
            android:exported="false" />
        <activity
            android:name="swasi.android.play.youtubeTutor.scaffolds.NavigationDrawerActivity"
